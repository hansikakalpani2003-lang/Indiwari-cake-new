        {
          "name": "Register — Valid Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Has token', () => pm.expect(body.token).to.be.a('string'));",
                  "pm.test('Has user object', () => pm.expect(body.user).to.be.an('object'));",
                  "pm.test('Role is customer', () => pm.expect(body.user.role).to.eql('customer'));",
                  "pm.environment.set('customer_token', body.token);",
                  "pm.environment.set('test_customer_id', body.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Customer M12\",\n  \"email\": \"testm12@indiwari.lk\",\n  \"password\": \"Test@1234\",\n  \"phone\": \"0771234567\"\n}"
