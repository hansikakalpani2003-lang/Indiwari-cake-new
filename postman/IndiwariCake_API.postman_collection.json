    {
      "name": "Orders",
      "item": [

        {
          "name": "POST /api/orders — Valid Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Has order id', () => pm.expect(body.order.id).to.be.a('number'));",
                  "pm.test('Has order_reference', () => pm.expect(body.order.order_reference).to.match(/^IC-\\d{8}-\\d{4}$/));",
                  "pm.test('Status is Pending', () => pm.expect(body.order.status).to.eql('Pending'));",
                  "pm.test('Has qr_code_token', () => pm.expect(body.order.qr_code_token).to.be.a('string'));",
                  "pm.environment.set('test_order_id', body.order.id);",
                  "pm.environment.set('test_qr_token', body.order.qr_code_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
