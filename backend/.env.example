# Server
PORT=5000
NODE_ENV=development

# Database — XAMPP MySQL defaults
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=indiwari_db

# JWT — change this to a long random string in production
JWT_SECRET=mysecretkey123
DELIVERY_JWT_SECRET=change_this_delivery_secret

# Cloudinary — get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email — Gmail address + a Gmail App Password (NOT your normal password)
# Generate one at https://myaccount.google.com/apppasswords
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password

# URLs
BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
